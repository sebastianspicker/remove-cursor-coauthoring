{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Config for remove-cursor-coauthor.sh",
  "type": "object",
  "properties": {
    "defaults": {
      "type": "object",
      "properties": {
        "dryRun": { "type": "boolean" },
        "noPush": { "type": "boolean" },
        "forcePush": { "type": "boolean" },
        "backupRemote": { "type": "string", "minLength": 1 }
      }
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "path"],
        "properties": {
          "url": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  }
}
